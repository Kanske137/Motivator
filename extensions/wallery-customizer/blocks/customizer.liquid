{% comment %}
  Wallery Customizer app block. Add it to the product template in the theme
  editor. It renders ONLY for products created via a Wallery template — detected
  via the `custom.template_slug` product metafield that the sync sets. The block
  outputs a mount point + context; wallery-widget.js mounts the customizer into a
  shadow DOM (isolated from the theme) and inherits the theme's fonts/colours.
{% endcomment %}

{%- assign wallery_slug = product.metafields.custom.template_slug.value -%}

{%- if wallery_slug != blank -%}
  <div
    data-wallery-root
    id="wallery-{{ block.id }}"
    data-product-handle="{{ product.handle }}"
    data-product-id="{{ product.id }}"
    data-template-slug="{{ wallery_slug }}"
    data-shop="{{ shop.permanent_domain }}"
    data-currency="{{ cart.currency.iso_code }}"
    data-locale="{{ request.locale.iso_code }}"
    data-accent="{{ block.settings.accent_color }}"
    data-radius="{{ block.settings.corner_radius }}"
    data-inherit-fonts="{{ block.settings.inherit_fonts }}"
    data-padding="{{ block.settings.padding }}"
    data-show-texts="{{ block.settings.show_texts }}"
    data-heading="{{ block.settings.heading | escape }}"
    data-subtext="{{ block.settings.subtext | escape }}"
    data-button-label="{{ block.settings.button_label | escape }}"
    data-overlay-title="{{ block.settings.overlay_title | escape }}"
    {{ block.shopify_attributes }}
  ></div>
  <script src="{{ 'wallery-widget.js' | asset_url }}" defer></script>
{%- else -%}
  {%- comment -%} Not a Wallery product — render nothing. {%- endcomment -%}
{%- endif -%}

{% schema %}
{
  "name": "Wallery Customizer",
  "target": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    {
      "type": "checkbox",
      "id": "show_texts",
      "label": "Show texts (heading + subtext)",
      "default": true
    },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Make it yours" },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Create your personal design before adding to cart."
    },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Open customizer" },
    { "type": "text", "id": "overlay_title", "label": "Title inside the customizer", "default": "Customize your design" },
    { "type": "header", "content": "Appearance" },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "inherit_fonts",
      "label": "Inherit theme fonts",
      "default": true
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "info": "Leave empty to inherit the theme's buy button."
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ]
}
{% endschema %}
